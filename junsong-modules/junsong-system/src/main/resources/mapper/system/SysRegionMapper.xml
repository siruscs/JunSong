<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.junsong.system.mapper.SysRegionMapper">

    <resultMap type="SysRegion" id="SysRegionResult">
        <id property="code" column="code" />
        <result property="name" column="name" />
        <result property="parentCode" column="parent_code" />
        <result property="level" column="level" />
        <result property="sort" column="sort" />
        <result property="status" column="status" />
        <result property="sourceYear" column="source_year" />
        <result property="sourceName" column="source_name" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectRegionVo">
        select code, name, parent_code, level, sort, status, source_year, source_name, create_time, update_time
        from sys_region
    </sql>

    <select id="selectRegionList" resultMap="SysRegionResult">
        <include refid="selectRegionVo"/>
        where status = '0'
        order by level asc, sort asc, code asc
    </select>

    <select id="selectChildrenByParentCode" parameterType="String" resultMap="SysRegionResult">
        <include refid="selectRegionVo"/>
        where parent_code = #{parentCode}
        order by sort asc, code asc
    </select>

    <select id="selectRegionByCode" parameterType="String" resultMap="SysRegionResult">
        <include refid="selectRegionVo"/>
        where code = #{code}
    </select>

    <insert id="insertRegion" parameterType="SysRegion">
        insert into sys_region(code, name, parent_code, level, sort, status, source_year, source_name, create_time, update_time)
        values(#{code}, #{name}, #{parentCode}, #{level}, #{sort}, #{status}, #{sourceYear}, #{sourceName}, sysdate(), sysdate())
    </insert>

    <update id="updateRegion" parameterType="SysRegion">
        update sys_region
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="parentCode != null and parentCode != ''">parent_code = #{parentCode},</if>
            <if test="level != null">level = #{level},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="sourceYear != null">source_year = #{sourceYear},</if>
            <if test="sourceName != null">source_name = #{sourceName},</if>
            update_time = sysdate()
        </set>
        where code = #{code}
    </update>

    <select id="countChildrenByParentCode" parameterType="String" resultType="int">
        select count(1) from sys_region where parent_code = #{parentCode}
    </select>

    <delete id="deleteRegionByCode" parameterType="String">
        delete from sys_region where code = #{code}
    </delete>
</mapper>
