<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.junsong.workflow.lowcode.mapper.LcBizPageSchemaMapper">

    <resultMap id="LcBizPageSchemaResult" type="com.junsong.workflow.lowcode.domain.LcBizPageSchema">
        <id property="id" column="id"/>
        <result property="bizCode" column="biz_code"/>
        <result property="pageType" column="page_type"/>
        <result property="schemaJson" column="schema_json"/>
        <result property="version" column="version"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectLcBizPageSchemaVo">
        select id, biz_code, page_type, schema_json, version, status, del_flag,
               create_by, create_time, update_by, update_time
        from lc_biz_page_schema
    </sql>

    <select id="selectLcBizPageSchemaList" parameterType="com.junsong.workflow.lowcode.domain.LcBizPageSchema" resultMap="LcBizPageSchemaResult">
        <include refid="selectLcBizPageSchemaVo"/>
        <where>
            del_flag = '0'
            <if test="bizCode != null and bizCode != ''">and biz_code = #{bizCode}</if>
            <if test="pageType != null and pageType != ''">and page_type = #{pageType}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by id desc
    </select>

    <select id="selectLcBizPageSchemaById" parameterType="Long" resultMap="LcBizPageSchemaResult">
        <include refid="selectLcBizPageSchemaVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectByBizCode" parameterType="String" resultMap="LcBizPageSchemaResult">
        <include refid="selectLcBizPageSchemaVo"/>
        where biz_code = #{bizCode} and del_flag = '0'
        order by id asc
    </select>

    <insert id="insertLcBizPageSchema" parameterType="com.junsong.workflow.lowcode.domain.LcBizPageSchema" useGeneratedKeys="true" keyProperty="id">
        insert into lc_biz_page_schema(
            biz_code, page_type, schema_json, version, status, del_flag,
            create_by, create_time, update_by, update_time
        ) values (
            #{bizCode}, #{pageType}, #{schemaJson}, #{version}, #{status}, #{delFlag},
            #{createBy}, sysdate(), #{updateBy}, sysdate()
        )
    </insert>

    <update id="updateLcBizPageSchema" parameterType="com.junsong.workflow.lowcode.domain.LcBizPageSchema">
        update lc_biz_page_schema
        <set>
            <if test="bizCode != null">biz_code = #{bizCode},</if>
            <if test="pageType != null">page_type = #{pageType},</if>
            <if test="schemaJson != null">schema_json = #{schemaJson},</if>
            <if test="version != null">version = #{version},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <update id="deleteLcBizPageSchemaByIds" parameterType="Long">
        update lc_biz_page_schema
        set del_flag = '2', update_time = sysdate()
        where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <delete id="physicalDeleteByBizCode" parameterType="String">
        delete from lc_biz_page_schema where biz_code = #{bizCode}
    </delete>

</mapper>
