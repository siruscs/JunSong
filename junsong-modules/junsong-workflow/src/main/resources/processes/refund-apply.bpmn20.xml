<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://www.junsong.com/workflow">
  <process id="refund_apply" name="会员退款申请" isExecutable="true">
    <startEvent id="StartEvent_1" name="发起退款申请"/>
    <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_StoreApprover"/>
    <userTask id="Task_StoreApprover" name="门店负责人审批" flowable:candidateUsers="${storeApprover}"/>
    <sequenceFlow id="Flow_2" sourceRef="Task_StoreApprover" targetRef="Gateway_Amount"/>
    <exclusiveGateway id="Gateway_Amount" name="金额判断"/>
    <sequenceFlow id="Flow_3" sourceRef="Gateway_Amount" targetRef="Task_Finance">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${refundAmount >= 1000}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_4" sourceRef="Gateway_Amount" targetRef="EndEvent_Approved">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${refundAmount < 1000}]]></conditionExpression>
    </sequenceFlow>
    <userTask id="Task_Finance" name="财务复核" flowable:candidateUsers="${financeApprover}"/>
    <sequenceFlow id="Flow_5" sourceRef="Task_Finance" targetRef="EndEvent_Approved"/>
    <endEvent id="EndEvent_Approved" name="审批完成"/>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_refund_apply">
    <bpmndi:BPMNPlane id="BPMNPlane_refund_apply" bpmnElement="refund_apply">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="250" y="240" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_StoreApprover" bpmnElement="Task_StoreApprover">
        <dc:Bounds x="400" y="200" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Gateway_Amount" bpmnElement="Gateway_Amount">
        <dc:Bounds x="580" y="230" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_Task_Finance" bpmnElement="Task_Finance">
        <dc:Bounds x="700" y="160" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_Approved" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="880" y="240" width="30" height="30"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="280" y="255"/>
        <di:waypoint x="400" y="240"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="500" y="240"/>
        <di:waypoint x="580" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="620" y="230"/>
        <di:waypoint x="620" y="200"/>
        <di:waypoint x="700" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint x="620" y="270"/>
        <di:waypoint x="620" y="255"/>
        <di:waypoint x="880" y="255"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_5" bpmnElement="Flow_5">
        <di:waypoint x="800" y="200"/>
        <di:waypoint x="880" y="200"/>
        <di:waypoint x="880" y="240"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
