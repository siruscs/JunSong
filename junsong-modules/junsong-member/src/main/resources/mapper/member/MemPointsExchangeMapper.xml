<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.junsong.member.mapper.MemPointsExchangeMapper">

    <resultMap type="com.junsong.member.domain.MemPointsExchange" id="MemPointsExchangeResult">
        <result property="exchangeId" column="exchange_id"/>
        <result property="deptId" column="dept_id"/>
        <result property="exchangeNo" column="exchange_no"/>
        <result property="memberId" column="member_id"/>
        <result property="memberNo" column="member_no"/>
        <result property="memberName" column="member_name"/>
        <result property="goodsId" column="goods_id"/>
        <result property="goodsName" column="goods_name"/>
        <result property="exchangeDate" column="exchange_date"/>
        <result property="quantity" column="quantity"/>
        <result property="pointsDeducted" column="points_deducted"/>
        <result property="actualPoints" column="actual_points"/>
        <result property="paymentMethod" column="payment_method"/>
        <result property="extraAmount" column="extra_amount"/>
        <result property="status" column="status"/>
        <result property="claimTime" column="claim_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectMemPointsExchangeVo">
        select exchange_id, dept_id, exchange_no, member_id, member_no, member_name,
               goods_id, goods_name, exchange_date, quantity, points_deducted, actual_points,
               payment_method, extra_amount, status, claim_time, create_by,
               create_time, update_by, update_time, del_flag
        from mem_points_exchange
    </sql>

    <select id="selectMemPointsExchangeList" parameterType="com.junsong.member.domain.MemPointsExchange" resultMap="MemPointsExchangeResult">
        <include refid="selectMemPointsExchangeVo"/>
        <where>
            <if test="exchangeNo != null and exchangeNo != ''">
                AND exchange_no like concat('%', #{exchangeNo}, '%')
            </if>
            <if test="memberId != null">
                AND member_id = #{memberId}
            </if>
            <if test="memberName != null and memberName != ''">
                AND member_name like concat('%', #{memberName}, '%')
            </if>
            <if test="goodsId != null">
                AND goods_id = #{goodsId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                AND date_format(create_time,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                AND date_format(create_time,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>
            AND del_flag = '0'
            ${params.dataScope}
        </where>
        order by create_time desc
    </select>

    <select id="selectMemPointsExchangeById" parameterType="Long" resultMap="MemPointsExchangeResult">
        <include refid="selectMemPointsExchangeVo"/>
        where exchange_id = #{exchangeId} and del_flag = '0'
    </select>

    <select id="checkMemExchangeNoUnique" parameterType="String" resultType="int">
        select count(1) from mem_points_exchange where exchange_no = #{exchangeNo} and del_flag = '0'
    </select>

    <insert id="insertMemPointsExchange" parameterType="com.junsong.member.domain.MemPointsExchange" useGeneratedKeys="true" keyProperty="exchangeId">
        insert into mem_points_exchange
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptId != null">dept_id,</if>
            <if test="exchangeNo != null and exchangeNo != ''">exchange_no,</if>
            <if test="memberId != null">member_id,</if>
            <if test="memberNo != null">member_no,</if>
            <if test="memberName != null">member_name,</if>
            <if test="goodsId != null">goods_id,</if>
            <if test="goodsName != null">goods_name,</if>
            <if test="exchangeDate != null">exchange_date,</if>
            <if test="quantity != null">quantity,</if>
            <if test="pointsDeducted != null">points_deducted,</if>
            <if test="actualPoints != null">actual_points,</if>
            <if test="paymentMethod != null">payment_method,</if>
            <if test="extraAmount != null">extra_amount,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptId != null">#{deptId},</if>
            <if test="exchangeNo != null and exchangeNo != ''">#{exchangeNo},</if>
            <if test="memberId != null">#{memberId},</if>
            <if test="memberNo != null">#{memberNo},</if>
            <if test="memberName != null">#{memberName},</if>
            <if test="goodsId != null">#{goodsId},</if>
            <if test="goodsName != null">#{goodsName},</if>
            <if test="exchangeDate != null">#{exchangeDate},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="pointsDeducted != null">#{pointsDeducted},</if>
            <if test="actualPoints != null">#{actualPoints},</if>
            <if test="paymentMethod != null">#{paymentMethod},</if>
            <if test="extraAmount != null">#{extraAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateMemPointsExchange" parameterType="com.junsong.member.domain.MemPointsExchange">
        update mem_points_exchange
        <trim prefix="SET" suffixOverrides=",">
            <if test="exchangeNo != null and exchangeNo != ''">exchange_no = #{exchangeNo},</if>
            <if test="memberId != null">member_id = #{memberId},</if>
            <if test="memberNo != null">member_no = #{memberNo},</if>
            <if test="memberName != null">member_name = #{memberName},</if>
            <if test="goodsId != null">goods_id = #{goodsId},</if>
            <if test="goodsName != null">goods_name = #{goodsName},</if>
            <if test="exchangeDate != null">exchange_date = #{exchangeDate},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="pointsDeducted != null">points_deducted = #{pointsDeducted},</if>
            <if test="paymentMethod != null">payment_method = #{paymentMethod},</if>
            <if test="extraAmount != null">extra_amount = #{extraAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="claimTime != null">claim_time = #{claimTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where exchange_id = #{exchangeId}
    </update>

    <delete id="deleteMemPointsExchangeById" parameterType="Long">
        update mem_points_exchange set del_flag = '1' where exchange_id = #{exchangeId}
    </delete>

    <delete id="deleteMemPointsExchangeByIds" parameterType="Long">
        update mem_points_exchange set del_flag = '1' where exchange_id in
        <foreach item="exchangeId" collection="array" open="(" separator="," close=")">
            #{exchangeId}
        </foreach>
    </delete>

</mapper>
