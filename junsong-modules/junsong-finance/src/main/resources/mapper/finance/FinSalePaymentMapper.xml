<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.junsong.finance.mapper.FinSalePaymentMapper">
    
    <resultMap type="FinSalePayment" id="FinSalePaymentResult">
        <id property="paymentId" column="payment_id" />
        <result property="deptId" column="dept_id" />
        <result property="periodId" column="period_id" />
        <result property="saleId" column="sale_id" />
        <result property="paymentNo" column="payment_no" />
        <result property="paymentAmount" column="payment_amount" />
        <result property="paymentMethod" column="payment_method" />
        <result property="paymentDate" column="payment_date" />
        <result property="delFlag" column="del_flag" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>
    
    <sql id="selectFinSalePaymentVo">
        select p.payment_id, p.dept_id, p.period_id, p.sale_id, p.payment_no, p.payment_amount, p.payment_method, p.payment_date, p.del_flag, p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        from fin_sale_payment p
    </sql>

    <select id="selectFinSalePaymentList" parameterType="FinSalePayment" resultMap="FinSalePaymentResult">
        <include refid="selectFinSalePaymentVo"/>
        <where>  
            p.del_flag = '0'
            <if test="deptId != null"> and p.dept_id = #{deptId}</if>
            <if test="periodId != null"> and p.period_id = #{periodId}</if>
            <if test="saleId != null"> and p.sale_id = #{saleId}</if>
            <if test="paymentNo != null and paymentNo != ''"> and p.payment_no like concat('%', #{paymentNo}, '%')</if>
        </where>
        order by p.create_time desc
    </select>
    
    <select id="selectFinSalePaymentBySaleId" parameterType="Long" resultMap="FinSalePaymentResult">
        <include refid="selectFinSalePaymentVo"/>
        where p.sale_id = #{saleId} and p.del_flag = '0'
    </select>
    
    <select id="selectFinSalePaymentByPaymentId" parameterType="Long" resultMap="FinSalePaymentResult">
        <include refid="selectFinSalePaymentVo"/>
        where p.payment_id = #{paymentId}
    </select>

    <select id="checkPaymentNoUnique" parameterType="String" resultMap="FinSalePaymentResult">
        <include refid="selectFinSalePaymentVo"/>
        where p.payment_no = #{paymentNo} and p.del_flag = '0' limit 1
    </select>

    <select id="countTodayPayments" resultType="int">
        select count(*) from fin_sale_payment where date(create_time) = curdate()
    </select>
        
    <insert id="insertFinSalePayment" parameterType="FinSalePayment" useGeneratedKeys="true" keyProperty="paymentId">
        insert into fin_sale_payment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptId != null">dept_id,</if>
            <if test="periodId != null">period_id,</if>
            <if test="saleId != null">sale_id,</if>
            <if test="paymentNo != null and paymentNo != ''">payment_no,</if>
            <if test="paymentAmount != null">payment_amount,</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method,</if>
            <if test="paymentDate != null">payment_date,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            create_time,
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptId != null">#{deptId},</if>
            <if test="periodId != null">#{periodId},</if>
            <if test="saleId != null">#{saleId},</if>
            <if test="paymentNo != null and paymentNo != ''">#{paymentNo},</if>
            <if test="paymentAmount != null">#{paymentAmount},</if>
            <if test="paymentMethod != null and paymentMethod != ''">#{paymentMethod},</if>
            <if test="paymentDate != null">#{paymentDate},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate(),
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <insert id="batchFinSalePayment" parameterType="java.util.List">
        insert into fin_sale_payment (
            dept_id, period_id, sale_id, payment_no, payment_amount, payment_method, payment_date, del_flag, create_by, create_time, remark
        )
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (
                #{item.deptId},
                #{item.periodId},
                #{item.saleId},
                #{item.paymentNo},
                #{item.paymentAmount},
                #{item.paymentMethod},
                #{item.paymentDate},
                #{item.delFlag},
                #{item.createBy},
                sysdate(),
                #{item.remark}
            )
        </foreach>
    </insert>

    <update id="updateFinSalePayment" parameterType="FinSalePayment">
        update fin_sale_payment
        <trim prefix="SET" suffixOverrides=",">
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="periodId != null">period_id = #{periodId},</if>
            <if test="saleId != null">sale_id = #{saleId},</if>
            <if test="paymentNo != null and paymentNo != ''">payment_no = #{paymentNo},</if>
            <if test="paymentAmount != null">payment_amount = #{paymentAmount},</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method = #{paymentMethod},</if>
            <if test="paymentDate != null">payment_date = #{paymentDate},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where payment_id = #{paymentId}
    </update>

    <delete id="deleteFinSalePaymentByPaymentId" parameterType="Long">
        update fin_sale_payment set del_flag = '2' where payment_id = #{paymentId}
    </delete>

    <delete id="deleteFinSalePaymentByPaymentIds" parameterType="Long">
        update fin_sale_payment set del_flag = '2' where payment_id in 
        <foreach item="paymentId" collection="array" open="(" separator="," close=")">
            #{paymentId}
        </foreach>
    </delete>

    <delete id="deleteFinSalePaymentBySaleId" parameterType="Long">
        update fin_sale_payment set del_flag = '2' where sale_id = #{saleId}
    </delete>

    <delete id="deleteFinSalePaymentBySaleIds" parameterType="Long">
        update fin_sale_payment set del_flag = '2' where sale_id in 
        <foreach item="saleId" collection="array" open="(" separator="," close=")">
            #{saleId}
        </foreach>
    </delete>
</mapper>
