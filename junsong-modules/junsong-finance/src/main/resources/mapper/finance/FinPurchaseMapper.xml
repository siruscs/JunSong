<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.junsong.finance.mapper.FinPurchaseMapper">
    
    <resultMap type="FinPurchase" id="FinPurchaseResult">
        <id     property="purchaseId"      column="purchase_id"      />

        <result property="periodId"        column="period_id"        />
        <result property="purchaseNo"      column="purchase_no"      />
        <result property="supplierId"      column="supplier_id"      />
        <result property="supplierName"    column="supplier_name"    />
        <result property="purchaseDate"    column="purchase_date"    />
        <result property="totalAmount"     column="total_amount"     />
        <result property="paidAmount"      column="paid_amount"      />
        <result property="paymentMethod"   column="payment_method"   />
        <result property="totalQuantity"   column="total_quantity"   />
        <result property="status"          column="status"           />
        <result property="receiverName"    column="receiver_name"    />
        <result property="receiverPhone"   column="receiver_phone"   />
        <result property="receiverAddress" column="receiver_address" />
        <result property="delFlag"         column="del_flag"         />
        <result property="deptId"          column="dept_id" />
        <result property="createBy"        column="create_by"        />
        <result property="createTime"      column="create_time"      />
        <result property="updateBy"        column="update_by"        />
        <result property="updateTime"      column="update_time"      />
        <result property="remark"          column="remark"           />
    </resultMap>
    
    <sql id="selectFinPurchaseVo">
        select p.purchase_id, p.period_id, p.purchase_no, p.supplier_id, s.supplier_name, p.purchase_date, p.total_amount, p.paid_amount, p.payment_method, p.total_quantity, p.status, p.receiver_name, p.receiver_phone, p.receiver_address, p.del_flag, p.dept_id, p.create_by, p.create_time, p.update_by, p.update_time, p.remark
        from fin_purchase p
        left join fin_supplier s on p.supplier_id = s.supplier_id
    </sql>

    <select id="selectFinPurchaseList" parameterType="FinPurchase" resultMap="FinPurchaseResult">
        <include refid="selectFinPurchaseVo"/>
        <where>  
            p.del_flag = '0'
            <if test="deptId != null"> and p.dept_id = #{deptId}</if>
            <if test="periodId != null"> and p.period_id = #{periodId}</if>
            <if test="purchaseNo != null  and purchaseNo != ''"> and p.purchase_no like concat('%', #{purchaseNo}, '%')</if>
            <if test="supplierId != null"> and p.supplier_id = #{supplierId}</if>
            <if test="status != null  and status != ''"> and p.status = #{status}</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                and date_format(p.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                and date_format(p.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
        order by p.create_time desc
    </select>
    
    <select id="selectFinPurchaseByPurchaseId" parameterType="Long" resultMap="FinPurchaseResult">
        <include refid="selectFinPurchaseVo"/>
        where p.purchase_id = #{purchaseId}
    </select>

    <select id="checkPurchaseNoUnique" parameterType="String" resultMap="FinPurchaseResult">
        <include refid="selectFinPurchaseVo"/>
        where p.purchase_no = #{purchaseNo} and p.del_flag = '0' limit 1
    </select>
        
    <insert id="insertFinPurchase" parameterType="FinPurchase" useGeneratedKeys="true" keyProperty="purchaseId">
        insert into fin_purchase
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="purchaseNo != null and purchaseNo != ''">purchase_no,</if>
            <if test="periodId != null">period_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="purchaseDate != null">purchase_date,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="paidAmount != null">paid_amount,</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method,</if>
            <if test="totalQuantity != null">total_quantity,</if>

            <if test="status != null">status,</if>
            <if test="receiverName != null and receiverName != ''">receiver_name,</if>
            <if test="receiverPhone != null and receiverPhone != ''">receiver_phone,</if>
            <if test="receiverAddress != null and receiverAddress != ''">receiver_address,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="createBy != null">create_by,</if>
            create_time,
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="purchaseNo != null and purchaseNo != ''">#{purchaseNo},</if>
            <if test="periodId != null">#{periodId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="purchaseDate != null">#{purchaseDate},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="paidAmount != null">#{paidAmount},</if>
            <if test="paymentMethod != null and paymentMethod != ''">#{paymentMethod},</if>
            <if test="totalQuantity != null">#{totalQuantity},</if>
            <if test="status != null">#{status},</if>
            <if test="receiverName != null and receiverName != ''">#{receiverName},</if>
            <if test="receiverPhone != null and receiverPhone != ''">#{receiverPhone},</if>
            <if test="receiverAddress != null and receiverAddress != ''">#{receiverAddress},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate(),
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateFinPurchase" parameterType="FinPurchase">
        update fin_purchase
        <trim prefix="SET" suffixOverrides=",">
            <if test="purchaseNo != null and purchaseNo != ''">purchase_no = #{purchaseNo},</if>
            <if test="periodId != null">period_id = #{periodId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="purchaseDate != null">purchase_date = #{purchaseDate},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="paidAmount != null">paid_amount = #{paidAmount},</if>
            <if test="paymentMethod != null and paymentMethod != ''">payment_method = #{paymentMethod},</if>
            <if test="totalQuantity != null">total_quantity = #{totalQuantity},</if>
            <if test="status != null">status = #{status},</if>
            <if test="receiverName != null">receiver_name = #{receiverName},</if>
            <if test="receiverPhone != null">receiver_phone = #{receiverPhone},</if>
            <if test="receiverAddress != null">receiver_address = #{receiverAddress},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where purchase_id = #{purchaseId}
    </update>

    <update id="deleteFinPurchaseByPurchaseId" parameterType="Long">
        update fin_purchase set del_flag = '2' where purchase_id = #{purchaseId}
    </update>

    <update id="deleteFinPurchaseByPurchaseIds" parameterType="Long">
        update fin_purchase set del_flag = '2' where purchase_id in 
        <foreach item="purchaseId" collection="array" open="(" separator="," close=")">
            #{purchaseId}
        </foreach>
    </update>

    <insert id="batchFinPurchaseDetail" parameterType="java.util.List">
        insert into fin_purchase_detail
        (purchase_id, product_id, product_name, unit, quantity, price, amount, is_gift, create_by, create_time, remark)
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (#{item.purchaseId}, #{item.productId}, #{item.productName}, #{item.unit}, #{item.quantity}, #{item.price}, #{item.amount}, #{item.isGift}, #{item.createBy}, sysdate(), #{item.remark})
        </foreach>
    </insert>

    <delete id="deleteFinPurchaseDetailByPurchaseIds" parameterType="Long">
        delete from fin_purchase_detail where purchase_id in 
        <foreach item="purchaseId" collection="array" open="(" separator="," close=")">
            #{purchaseId}
        </foreach>
    </delete>

    <delete id="deleteFinPurchaseDetailByPurchaseId" parameterType="Long">
        delete from fin_purchase_detail where purchase_id = #{purchaseId}
    </delete>
    
    <select id="countTodayPurchases" resultType="int">
        select count(*) from fin_purchase
        where date(create_time) = curdate()
        and del_flag = '0'
    </select>

</mapper>
