<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.junsong.finance.mapper.FinAdvanceMapper">
    
    <resultMap type="FinAdvance" id="FinAdvanceResult">
        <id property="advanceId" column="advance_id" />
        <result property="deptId" column="dept_id" />
        <result property="periodId" column="period_id" />
        <result property="advanceNo" column="advance_no" />
        <result property="advanceDate" column="advance_date" />
        <result property="advanceAmount" column="advance_amount" />
        <result property="borrower" column="borrower" />
        <result property="purpose" column="purpose" />
        <result property="status" column="status" />
        <result property="verifyBy" column="verify_by" />
        <result property="verifyTime" column="verify_time" />
        <result property="delFlag" column="del_flag" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>
    
    <sql id="selectFinAdvanceVo">
        select a.advance_id, a.dept_id, a.period_id, a.advance_no, a.advance_date, a.advance_amount, a.borrower, a.purpose, a.status, a.verify_by, a.verify_time, a.del_flag, a.create_by, a.create_time, a.update_by, a.update_time, a.remark
        from fin_advance a
    </sql>

    <select id="selectFinAdvanceList" parameterType="FinAdvance" resultMap="FinAdvanceResult">
        <include refid="selectFinAdvanceVo"/>
        <where>  
            a.del_flag = '0'
            <if test="deptId != null"> and a.dept_id = #{deptId}</if>
            <if test="periodId != null"> and a.period_id = #{periodId}</if>
            <if test="advanceNo != null and advanceNo != ''"> and a.advance_no like concat('%', #{advanceNo}, '%')</if>
            <if test="borrower != null and borrower != ''"> and a.borrower like concat('%', #{borrower}, '%')</if>
            <if test="status != null and status != ''"> and a.status = #{status}</if>
        </where>
        order by a.create_time desc
    </select>
    
    <select id="selectFinAdvanceByAdvanceId" parameterType="Long" resultMap="FinAdvanceResult">
        <include refid="selectFinAdvanceVo"/>
        where a.advance_id = #{advanceId}
    </select>

    <select id="selectFinAdvanceByAdvanceIds" parameterType="Long" resultMap="FinAdvanceResult">
        <include refid="selectFinAdvanceVo"/>
        where a.advance_id in
        <foreach item="advanceId" collection="array" open="(" separator="," close=")">
            #{advanceId}
        </foreach>
    </select>

    <select id="checkAdvanceNoUnique" parameterType="String" resultMap="FinAdvanceResult">
        <include refid="selectFinAdvanceVo"/>
        where a.advance_no = #{advanceNo} and a.del_flag = '0' limit 1
    </select>

    <select id="countTodayAdvances" resultType="int">
        select count(*) from fin_advance where date(create_time) = curdate()
    </select>
        
    <select id="sumUnverifiedAdvances" resultType="java.math.BigDecimal">
        select ifnull(sum(advance_amount), 0) from fin_advance where status = '0' and del_flag = '0'
    </select>

    <select id="sumUnverifiedAdvancesByDeptId" resultType="java.math.BigDecimal">
        select ifnull(sum(advance_amount), 0)
        from fin_advance
        where status = '0' and del_flag = '0'
        <if test="deptId != null"> and dept_id = #{deptId}</if>
    </select>
        
    <insert id="insertFinAdvance" parameterType="FinAdvance" useGeneratedKeys="true" keyProperty="advanceId">
        insert into fin_advance
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptId != null">dept_id,</if>
            <if test="periodId != null">period_id,</if>
            <if test="advanceNo != null and advanceNo != ''">advance_no,</if>
            <if test="advanceDate != null">advance_date,</if>
            <if test="advanceAmount != null">advance_amount,</if>
            <if test="borrower != null and borrower != ''">borrower,</if>
            <if test="purpose != null and purpose != ''">purpose,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            create_time,
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptId != null">#{deptId},</if>
            <if test="periodId != null">#{periodId},</if>
            <if test="advanceNo != null and advanceNo != ''">#{advanceNo},</if>
            <if test="advanceDate != null">#{advanceDate},</if>
            <if test="advanceAmount != null">#{advanceAmount},</if>
            <if test="borrower != null and borrower != ''">#{borrower},</if>
            <if test="purpose != null and purpose != ''">#{purpose},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate(),
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateFinAdvance" parameterType="FinAdvance">
        update fin_advance
        <trim prefix="SET" suffixOverrides=",">
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="periodId != null">period_id = #{periodId},</if>
            <if test="advanceNo != null and advanceNo != ''">advance_no = #{advanceNo},</if>
            <if test="advanceDate != null">advance_date = #{advanceDate},</if>
            <if test="advanceAmount != null">advance_amount = #{advanceAmount},</if>
            <if test="borrower != null and borrower != ''">borrower = #{borrower},</if>
            <if test="purpose != null and purpose != ''">purpose = #{purpose},</if>
            <if test="status != null">status = #{status},</if>
            <if test="verifyBy != null">verify_by = #{verifyBy},</if>
            <if test="verifyTime != null">verify_time = #{verifyTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where advance_id = #{advanceId}
    </update>

    <delete id="deleteFinAdvanceByAdvanceId" parameterType="Long">
        update fin_advance set del_flag = '2' where advance_id = #{advanceId}
    </delete>

    <delete id="deleteFinAdvanceByAdvanceIds" parameterType="Long">
        update fin_advance set del_flag = '2' where advance_id in 
        <foreach item="advanceId" collection="array" open="(" separator="," close=")">
            #{advanceId}
        </foreach>
    </delete>
</mapper>
